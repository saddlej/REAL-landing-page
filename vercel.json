{
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/RL-:id", "destination": "/profile.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
