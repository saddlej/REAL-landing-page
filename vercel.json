{
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/RL-:id", "destination": "/profile.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/billing", "destination": "/billing.html" },
    { "source": "/api/badge", "destination": "/api/domain-verify?action=badge" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
